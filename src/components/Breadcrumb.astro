---
interface Props {
  current: string;
}

const { current } = Astro.props;
---

<section class="breadcrumb-band">
  <div class="container-figma breadcrumb">
    <a href="/">Home</a>
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="breadcrumb-chevron">
      <path d="M4 4.5 8.5 9 4 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M9.5 4.5 14 9l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>{current}</span>
  </div>
</section>
