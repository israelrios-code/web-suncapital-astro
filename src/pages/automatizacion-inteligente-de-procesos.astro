---
import "../styles/global.css";
import GoogleTagManagerHead from "../components/GoogleTagManagerHead.astro";
import GoogleTagManagerBody from "../components/GoogleTagManagerBody.astro";
import Nav from "../components/Nav.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import CitiesCarousel from "../components/CitiesCarousel.astro";
import data from "../content/automation.json";
import home from "../content/home.json";

---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Automatización inteligente de procesos | Suncapital</title>
    <meta name="description" content={data.hero.body} />
      <GoogleTagManagerHead />
  </head>
  <body>
    <GoogleTagManagerBody />
    <Nav />

    <main class="pt-[102px] bg-white">
      <Breadcrumb current="Automatización inteligente de procesos" />
      <section class="relative overflow-hidden bg-ink py-[110px] dark-orb">
        <img src="/assets/deco/lineas-hero-todas-las-secciones.svg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none z-[1] opacity-20" />
        <div class="container-figma relative grid grid-cols-[760px_1fr] gap-20 items-center max-lg:grid-cols-1">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2.5 text-white section-copy">
              <i class="size-2 rounded-full bg-secondary"></i>{data.hero.eyebrow}
            </span>
            <h1 class="mt-6 text-white text-[64px] leading-[68px] font-bold max-lg:text-[44px] max-lg:leading-[48px]">
              <span class="text-accent">{data.hero.titleAccent}</span> {data.hero.title}
            </h1>
            <p class="mt-8 max-w-[690px] text-white text-[18px] leading-[22px] font-medium">{data.hero.body}</p>
            <a href="#contacto" class="btn-primary mt-10">{data.hero.button}</a>
          </div>
          <div class="reveal relative">
            <div class="absolute -left-8 top-10 h-[88%] w-[88%] rounded-[36px] border border-secondary/25"></div>
            <img src={data.hero.image} alt="" class="relative h-[520px] w-full rounded-[34px] object-cover shadow-2xl" />
            <div class="absolute -bottom-8 left-10 rounded-2xl bg-white p-5 shadow-2xl">
              <p class="text-primary text-[28px] leading-8 font-bold">-81%</p>
              <p class="section-copy">tiempo de onboarding</p>
            </div>
          </div>
        </div>
      </section>


      <section class="bg-white py-20 max-lg:py-[60px]">
        <div class="container-figma">
          <h2 class="section-title mx-auto max-w-[860px] text-center text-primary reveal">{data.capabilities.title}</h2>
          <div class="mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1">
            {data.capabilities.items.map(([title, body, cta, href, icon]) => (
              <article class="reveal flex flex-col overflow-hidden rounded-3xl bg-ink p-8 text-white dark-card">
                <div class="flex-1">
                  <img src={icon} alt="" class="mb-5 size-12 object-contain" />
                  <h3 class="card-title text-secondary">{title}</h3>
                  <p class="section-copy mt-4">{body}</p>
                </div>
                <a href={href} class="btn-text btn-text-white mt-8">{cta} <span>→</span></a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="relative overflow-hidden bg-ink py-[120px] max-lg:py-[60px] dark-orb">
        <div class="container-figma relative text-center text-white">
          <h2 class="section-title reveal">{data.solutions.title}</h2>
          <p class="section-copy mx-auto mt-5 max-w-[820px] reveal">{data.solutions.body}</p>
          <div class="mt-10 grid grid-cols-3 gap-6 text-left max-lg:grid-cols-1">
            {data.solutions.items.map(([title, body, button, image, tag]) => (
              <article class="group reveal relative min-h-[582px] max-lg:min-h-[400px] overflow-hidden rounded-[28px] p-10 flex flex-col justify-end">
                <img src={image} alt={title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-[#0F172A]/70"></div>
                <div class="relative">
                  <span class="inline-flex rounded-full bg-accent px-3 py-1 text-white text-sm leading-[18px]">{tag}</span>
                  <h3 class="card-title mt-4 text-white">{title}</h3>
                  <p class="section-copy mt-4 text-white/80">{body}</p>
                  <a class="btn-primary mt-[18px]" href="#contacto">{button}</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-surface py-20 max-lg:py-[60px]">
        <div class="container-figma">
          <h2 class="section-title text-center text-primary reveal">{data.why.title}</h2>
          <div class="mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1">
            {data.why.items.map(([title, body, icon]) => (
              <article class="reveal rounded-2xl border border-border bg-white p-7 shadow-sm">
                <img src={icon} alt="" class="mb-4 size-12 object-contain" />
                <h3 class="card-title text-primary">{title}</h3>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma reveal relative overflow-hidden rounded-3xl bg-ink p-10 max-lg:p-7 dark-orb">
          <img src="/assets/deco/lineas-hero-banner.svg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none z-[1] opacity-20" />
          <div class="relative z-[2] grid grid-cols-[1fr_1.1fr] gap-20 max-lg:gap-[60px] items-center max-lg:grid-cols-1">
            <div class="flex flex-col gap-4">
              <h2 class="text-white text-[48px] leading-[52px] font-bold max-lg:text-[34px] max-lg:leading-[38px]">{data.onboard.titleBefore} <span class="text-secondary">{data.onboard.titleHighlight}</span> {data.onboard.titleAfter}</h2>
              <p class="section-copy text-white">{data.onboard.body}</p>
              <div class="rounded-2xl bg-[#5C58ED]/20 p-4">
                <ul class="list-disc pl-6 section-copy text-white space-y-1">
                  {data.onboard.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>
              <a class="btn-primary mt-2 self-start" href="/onboard">{data.onboard.button}</a>
            </div>
            <div class="relative">
              <img src={data.onboard.image} alt="" class="w-full" />
              <img src={data.onboard.badge} alt="" class="absolute left-[45%] top-[-24px] w-[270px] max-lg:w-[160px] max-lg:left-[38%] rounded-lg shadow-2xl" />
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white py-20 max-lg:py-[60px]">
        <div class="container-figma grid grid-cols-[1fr_560px] gap-20 items-center max-lg:grid-cols-1">
          <div class="reveal">
            <h2 class="section-title text-primary">{data.audience.title}</h2>
            <p class="section-copy mt-5">{data.audience.body}</p>
            <ul class="mt-8 grid gap-4">
              {data.audience.items.map((item) => (
                <li class="flex gap-4 section-copy text-primary">
                  <span class="mt-1 grid size-5 shrink-0 place-items-center rounded-full bg-secondary text-primary text-xs font-bold">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <img src={data.audience.image} alt="" class="reveal h-[560px] w-full rounded-[32px] object-cover shadow-xl" />
        </div>
      </section>

      <section class="bg-surface py-[120px] max-lg:py-[60px]">
        <div class="container-figma text-center reveal">
          <h2 class="section-title text-primary">{data.logos.title} <span class="text-accent">{data.logos.highlight}</span></h2>
          <p class="section-copy mt-4">{data.logos.body}</p>
          <div class="mt-20 max-lg:mt-10 grid grid-cols-9 gap-4 max-lg:grid-cols-3">
            {data.logos.items.map((logo) => <div class="h-[62px] rounded-lg bg-white flex items-center justify-center px-4"><img src={logo} alt="" class="max-h-[50px] object-contain" /></div>)}
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma reveal relative min-h-[520px] overflow-hidden rounded-3xl p-20 flex items-center max-lg:items-end max-lg:p-6 max-lg:pb-8 max-lg:min-h-[480px]">
          <img src={data.ctaOne.image} alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-[linear-gradient(80deg,#1d1d1b_24%,rgba(29,29,27,.2)_76%)] max-lg:bg-[linear-gradient(0deg,#1d1d1b_45%,rgba(29,29,27,0.2)_85%)]"></div>
          <img src="/assets/deco/lineas-hero-banner.svg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none z-[1] opacity-20" />
          <div class="relative z-[2] max-w-[620px] text-white">
            <h2 class="section-title">{data.ctaOne.title}</h2>
            <p class="section-copy mt-5">{data.ctaOne.body}</p>
            <a class="btn-primary mt-6" href="#contacto">{data.ctaOne.button}</a>
          </div>
        </div>
      </section>

      <section class="bg-white py-20 max-lg:py-[60px]">
        <div class="container-figma flex flex-col items-center gap-10">
          <header class="reveal flex flex-col items-center gap-4 text-center">
            <span class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-[10px] text-primary section-copy"><i class="size-2 rounded-full bg-secondary"></i>{data.caseStudy.kicker}</span>
            <h2 class="text-primary text-[48px] leading-[52px] font-bold">{data.caseStudy.title}</h2>
            <p class="section-copy max-w-[760px]">{data.caseStudy.body}</p>
          </header>
          <article class="reveal relative w-full overflow-hidden rounded-3xl bg-ink border border-white/10 p-20 flex flex-col items-center gap-10 dark-orb max-lg:p-8">
            <span class="rounded-full bg-secondary/20 px-3 py-1 text-secondary section-copy relative">{data.caseStudy.tag}</span>
            <div class="relative grid grid-cols-3 gap-10 w-full max-lg:grid-cols-1">
              {data.caseStudy.steps.map(([title, body], index) => (
                <div class="flex flex-col gap-3">
                  <div class="flex items-center gap-2">
                    <span class="inline-grid size-6 shrink-0 place-items-center rounded-full bg-secondary text-primary text-base font-normal">{index + 1}</span>
                    <h3 class="text-surface font-semibold text-[20px] leading-6">{title}</h3>
                  </div>
                  <p class="section-copy text-white">{body}</p>
                </div>
              ))}
            </div>
            <div class="relative grid grid-cols-3 gap-20 w-full border-t border-white/60 pt-8 max-lg:grid-cols-1 max-lg:gap-6">
              {data.caseStudy.metrics.map(([value, label]) => (
                <div>
                  <strong class="block text-[68px] leading-[72px] font-bold text-secondary">{value}</strong>
                  <p class="section-copy text-white mt-1">{label}</p>
                </div>
              ))}
            </div>
          </article>
        </div>
      </section>

      <section class="bg-white py-20 max-lg:py-[60px] text-center">
        <div class="container-figma reveal">
          <h2 class="section-title text-primary">{data.certifications.title}</h2>
          <p class="section-copy mx-auto mt-[18px] max-w-[1250px]">{data.certifications.body}</p>
          <div class="mt-10 grid grid-cols-4 gap-4 text-left max-lg:grid-cols-1">
            {data.certifications.items.map(([kicker, title, image]) => (
              <article class="rounded-3xl bg-border p-8">
                {image && <img src={image} alt="" class="mb-4 h-[54px] w-[146px] object-contain rounded-lg bg-white p-2" />}
                <p class="text-accent text-[18px] leading-[22px] font-medium">{kicker}</p>
                <h3 class="card-title mt-3 text-primary">{title}</h3>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="relative overflow-hidden bg-ink py-20 max-lg:py-[60px] dark-orb [&::after]:hidden">
        <div class="container-figma relative text-center">
          <h2 class="section-title text-white reveal">{data.process.title}</h2>
          <div class="mt-10 grid grid-cols-4 gap-6 text-left max-lg:grid-cols-1">
            {data.process.items.map(([num, title, body, icon]) => (
              <article class="reveal rounded-3xl bg-primary p-8 text-white">
                <div class="flex items-start justify-between mb-6">
                  <p class="text-[56px] leading-[60px] font-bold text-white/20">{num}</p>
                  <img src={icon} alt="" class="size-10 object-contain" />
                </div>
                <h3 class="card-title">{title}</h3>
                <p class="section-copy mt-4">{body}</p>
              </article>
            ))}
          </div>
          <a href="#contacto" class="btn-primary mt-10">{data.process.button} →</a>
        </div>
      </section>

      <section class="relative overflow-hidden bg-ink py-[120px] max-lg:py-[60px] dark-orb [&::before]:hidden">
        <div class="container-figma relative text-white">
          <h2 class="section-title text-center reveal">{data.otherIndustries.title}</h2>
          <div class="mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1">
            {data.otherIndustries.items.map(([title, body, image]) => (
              <article class="group reveal relative min-h-[430px] overflow-hidden rounded-[28px] p-8 flex items-end">
                <img src={image} alt={title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/50 to-transparent"></div>
                <div class="relative">
                  <h3 class="card-title text-secondary">{title}</h3>
                  <p class="section-copy mt-4">{body}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="bg-white py-20">
        <div class="container-figma reveal relative min-h-[520px] overflow-hidden rounded-3xl p-20 flex items-center max-lg:items-end max-lg:p-6 max-lg:pb-8 max-lg:min-h-[480px]">
          <img src={data.finalCta.image} alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-[linear-gradient(80deg,#1d1d1b_28%,rgba(29,29,27,.08)_88%)] max-lg:bg-[linear-gradient(0deg,#1d1d1b_45%,rgba(29,29,27,0.2)_85%)]"></div>
          <img src="/assets/deco/lineas-hero-banner.svg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none z-[1] opacity-20" />
          <div class="relative z-[2] max-w-[690px] text-white">
            <h2 class="section-title">{data.finalCta.title}</h2>
            <p class="section-copy mt-5">{data.finalCta.body}</p>
            <a class="btn-primary mt-6" href={`mailto:${home.footer.email}`}>{data.finalCta.button}</a>
          </div>
        </div>
      </section>

      <section class="bg-white py-20 max-lg:py-[60px]">
        <div class="container-figma grid grid-cols-[338px_1fr] gap-20 max-lg:gap-8 items-start max-lg:grid-cols-1">
          <h2 class="section-title text-primary reveal">{data.faq.title}</h2>
          <div class="grid gap-5">
            {data.faq.items.map(([question, answer]) => (
              <details class="reveal group rounded-xl border-2 border-border px-[26px] py-[18px]">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-6 card-title max-lg:text-[18px] max-lg:leading-[22px] text-primary group-open:text-accent">
                  {question}
                  <span class="grid size-8 shrink-0 place-items-center rounded-full bg-surface text-primary text-base group-open:bg-accent group-open:text-white">
                    <span class="group-open:hidden">+</span>
                    <span class="hidden group-open:inline leading-none">−</span>
                  </span>
                </summary>
                <p class="section-copy mt-4 text-ink">{answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <CitiesCarousel title={data.cities.title} body={data.cities.body} items={data.cities.items} />
      </section>
    </main>

    <footer class="bg-ink py-20 text-white">
      <div class="container-figma grid grid-cols-4 gap-10 max-lg:grid-cols-1">
        <div>
          <a href="/"><img src="/assets/logo-footer.svg" alt="Suncapital" width="270" height="40" class="h-9 w-auto" /></a>
          <p class="mt-6 font-manrope section-copy">{home.footer.body}</p>
          <a href="https://www.linkedin.com/company/suncapital" target="_blank" rel="noopener noreferrer" class="mt-6 block w-max"><img src="/assets/icons/icon-linkedin-social.svg" alt="LinkedIn Suncapital" width="30" height="30" class="w-10 h-10" /></a><p class="mt-6 font-manrope section-copy">© 2025 Suncapital. Todos los derechos reservados.</p>
          <div class="mt-6 grid gap-3 underline font-manrope section-copy"><a href="#">Política de Calidad y Seguridad</a><a href="#">Política de Privacidad</a><a href="#">Aviso Legal</a><a href="#">Canal Ético</a></div>
        </div>
        <div><h3 class="font-manrope text-secondary text-[28px] leading-8 font-bold">Oficinas</h3><p class="mt-6 font-manrope text-xl leading-6 font-bold">{home.footer.office}</p><p class="mt-1 font-manrope section-copy">{home.footer.address}</p><p class="mt-6 font-manrope section-copy">{home.footer.coverage}</p></div>
        <div class="grid gap-4 text-[18px] leading-[22px] font-bold">{[["Sobre nosotros","/sobre-nosotros"],["Noticias","/noticias"],["Software Onboard","/onboard"],["Servicios","/#servicios"],["Automatización inteligente de procesos","/automatizacion-inteligente-de-procesos"],["Business Process Outsourcing","/business-process-outsourcing"],["Auditoría Catastral","/auditoria-catastral"],["Industrias","/#industrias"],["Banca, Financieras y Seguros","/banca-financieras-seguros"],["Real Estate y Servicing","/real-estate-servicing"],["Gran Consumo","/gran-consumo"],["Tecnología para gestión operativa","/tecnologia-gestion-operativa"]].map(([label, href]) => <a href={href} class={`${label === "Servicios" || label === "Industrias" ? "text-secondary" : "text-white"} hover:text-secondary transition-colors`}>{label}{label !== "Servicios" && label !== "Industrias" && <span class="float-right">→</span>}</a>)}</div>
        <div><a class="btn-primary" href={`mailto:${home.footer.email}`}>Contacto</a><p class="mt-6 text-sm leading-[18px]">{home.footer.email}</p><p class="mt-4 text-sm leading-[18px]">{home.footer.phone}</p><div class="mt-6 flex flex-col gap-2"><div class="flex gap-2"><img src="/assets/figma/cert-27001.png" alt="ISO 27001" class="h-16 rounded bg-white p-2 object-contain" /><img src="/assets/figma/cert-9001.png" alt="ISO 9001" class="h-16 rounded bg-white p-2 object-contain" /></div><img src="/assets/figma/cert-bde.png" alt="Banco de España" class="h-20 w-full rounded bg-white p-1 object-contain" /></div></div>
      </div>
    </footer>

    <script>
      const els = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("is-visible");
        });
      }, { threshold: 0.12 });
      els.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
