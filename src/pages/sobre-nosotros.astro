---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import data from "../content/about.json";
import home from "../content/home.json";

const icons = ["◇", "◱", "◌"];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sobre Nosotros | Suncapital</title>
    <meta name="description" content={data.hero.body} />
  </head>
  <body>
    <Nav />

    <main class="pt-[102px] bg-white">
      <Breadcrumb current="Sobre nosotros" />
      <section class="relative min-h-[862px] overflow-hidden bg-ink flex items-center">
        <img src={data.hero.image} alt="" class="absolute inset-0 h-full w-full object-cover" />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(29,29,27,.15)_0%,#1d1d1b_100%),linear-gradient(90deg,#1d1d1b_0%,rgba(29,29,27,.75)_42%,rgba(29,29,27,.1)_100%)]"></div>
        <div class="container-figma relative">
          <div class="reveal max-w-[910px] text-white">
            <h1 class="text-[68px] leading-[72px] font-bold max-lg:text-[44px] max-lg:leading-[48px]">
              {data.hero.title.split(data.hero.highlight)[0]}<span class="text-accent">{data.hero.highlight}</span>
            </h1>
            <p class="mt-10 max-w-[842px] text-[18px] leading-[22px] font-medium">{data.hero.body}</p>
            <a href="#contacto" class="btn-primary mt-10">{data.hero.button}</a>
          </div>
        </div>
      </section>

      <section class="bg-surface py-20">
        <div class="container-figma grid grid-cols-[883px_1fr] gap-20 items-center max-xl:grid-cols-[1fr_477px] max-lg:grid-cols-1">
          <img src={data.mission.image} alt="" class="reveal h-[642px] w-full rounded-3xl object-cover max-lg:h-[420px]" />
          <div class="reveal">
            <h2 class="text-primary text-[48px] leading-[52px] font-bold max-lg:text-[34px] max-lg:leading-[38px]">{data.mission.title}</h2>
            <p class="section-copy mt-8">{data.mission.body}</p>
          </div>
        </div>
        <div class="container-figma mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1">
          {data.mission.items.map((item, index) => (
            <article class="reveal min-h-[258px] rounded-3xl bg-primary p-8 text-white">
              <span class="grid size-12 place-items-center rounded-2xl bg-accent text-white text-2xl">{icons[index]}</span>
              <h3 class="card-title mt-[18px] text-secondary">{item.title}</h3>
              <p class="section-copy mt-4">{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="bg-border py-20">
        <div class="container-figma grid grid-cols-[612px_1fr] gap-20 items-start max-lg:grid-cols-1">
          <div class="reveal sticky top-[142px] max-lg:static">
            <h2 class="text-primary text-[48px] leading-[52px] font-bold">{data.history.title}</h2>
            <img src={data.history.image} alt="" class="mt-10 h-[612px] w-full rounded-3xl object-cover max-lg:h-[420px]" />
          </div>
          <div class="relative grid gap-6">
            <div class="absolute left-[52px] top-4 bottom-4 w-px bg-primary/25 max-sm:hidden"></div>
            {data.history.items.map((item) => (
              <article class="reveal relative grid grid-cols-[104px_1fr] gap-6 rounded-3xl bg-white p-8 shadow-sm max-sm:grid-cols-1">
                <div class="relative z-10">
                  <span class="grid size-[104px] place-items-center rounded-full bg-surface text-primary text-[28px] leading-8 font-semibold">{item.year}</span>
                </div>
                <div>
                  <h3 class="card-title text-accent">{item.title}</h3>
                  <p class="section-copy mt-4 text-ink">{item.body}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="relative overflow-hidden bg-ink py-20 dark-orb">
        <div class="container-figma relative text-center text-white">
          <h2 class="mx-auto max-w-[1020px] text-[48px] leading-[52px] font-bold reveal">
            {data.team.title.split(data.team.highlight)[0]}<span class="text-secondary">{data.team.highlight}</span>{data.team.title.split(data.team.highlight)[1]}
          </h2>
          <p class="section-copy mx-auto mt-[18px] max-w-[1250px] reveal">{data.team.body}</p>
          <div class="mt-10 grid grid-cols-4 gap-6 text-left max-lg:grid-cols-2 max-sm:grid-cols-1">
            {data.team.items.map((person) => (
              <article class="group reveal overflow-hidden rounded-3xl border border-border bg-white text-ink">
                <div class="relative h-[276px] overflow-hidden">
                  <img src={person.image} alt={person.name} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
                  <span class="absolute left-5 top-5 grid size-14 place-items-center rounded-2xl bg-surface text-primary font-bold">in</span>
                </div>
                <div class="p-8">
                  <h3 class="text-accent text-[28px] leading-8 font-semibold">{person.name}</h3>
                  <p class="mt-3 text-[18px] leading-[22px] font-medium">{person.role}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma grid grid-cols-[412px_1fr] gap-20 items-center max-lg:grid-cols-1">
          <div class="reveal">
            <h2 class="text-primary text-[48px] leading-[52px] font-bold">{data.recognitions.title}</h2>
            <p class="section-copy mt-[18px]">{data.recognitions.body}</p>
          </div>
          <div class="reveal grid grid-cols-[108px_108px_1fr_1fr] gap-10 items-center max-xl:grid-cols-2">
            {data.recognitions.images.map((image) => <img src={image} alt="" class="max-h-[112px] w-full object-contain" />)}
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma text-center">
          <h2 class="text-primary text-[48px] leading-[52px] font-bold reveal">{data.certifications.title}</h2>
          <p class="section-copy mx-auto mt-[18px] max-w-[1250px] reveal">{data.certifications.body}</p>
          <div class="mt-10 grid grid-cols-4 gap-4 text-left max-lg:grid-cols-1">
            {data.certifications.items.map((item) => (
              <article class="reveal rounded-3xl bg-border p-8">
                {item.image ? <img src={item.image} alt="" class="h-[54px] max-w-[284px] object-contain rounded-lg bg-white/70" /> : <div class="h-[54px]"></div>}
                <p class="mt-4 text-accent text-[18px] leading-[22px] font-medium">{item.status}</p>
                <h3 class="card-title mt-3 text-primary">{item.title}</h3>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contacto" class="bg-surface py-20">
        <div class="container-figma reveal relative min-h-[460px] overflow-hidden rounded-3xl p-20 flex items-center max-lg:p-8">
          <img src={data.finalCta.image} alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-[linear-gradient(80deg,#1d1d1b_27%,rgba(29,29,27,0)_87%),linear-gradient(0deg,#1d1d1b_5%,rgba(29,29,27,0)_45%)]"></div>
          <div class="relative max-w-[640px] text-white">
            <h2 class="text-[48px] leading-[52px] font-bold max-lg:text-[34px] max-lg:leading-[38px]">{data.finalCta.title}</h2>
            <p class="section-copy mt-5">{data.finalCta.body}</p>
            <a class="btn-primary mt-5" href={`mailto:${home.footer.email}`}>{data.finalCta.button}</a>
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma grid grid-cols-[338px_1fr] gap-20 items-start max-lg:grid-cols-1">
          <h2 class="text-primary text-[48px] leading-[52px] font-bold reveal">{data.faq.title}</h2>
          <div class="grid gap-5">
            {data.faq.items.map((question) => (
              <details class="reveal rounded-xl border-2 border-border px-[26px] py-[18px]">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-8 text-primary text-[28px] leading-8 font-semibold">
                  {question}<span class="grid size-8 shrink-0 place-items-center rounded-full bg-surface text-primary text-base">+</span>
                </summary>
              </details>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-ink py-20 text-white">
      <div class="container-figma grid grid-cols-4 gap-10 max-lg:grid-cols-1">
        <div>
          <strong class="block text-[30px] leading-none">SC <span class="text-white/60">|</span> <span class="text-[24px]">suncapital</span></strong>
          <p class="mt-6 font-manrope section-copy">{home.footer.body}</p>
          <p class="mt-6 font-manrope section-copy">© 2025 Suncapital. Todos los derechos reservados.</p>
          <div class="mt-6 grid gap-3 underline font-manrope section-copy"><a href="#">Política de Calidad y Seguridad</a><a href="#">Política de Privacidad</a><a href="#">Aviso Legal</a><a href="#">Canal Ético</a></div>
        </div>
        <div><h3 class="font-manrope text-secondary text-[28px] leading-8 font-bold">Oficinas</h3><p class="mt-6 font-manrope text-xl leading-6 font-bold">{home.footer.office}</p><p class="mt-1 font-manrope section-copy">{home.footer.address}</p><p class="mt-6 font-manrope section-copy">{home.footer.coverage}</p></div>
        <div class="grid gap-4 text-[18px] leading-[22px] font-bold">{["Sobre nosotros", "Noticias", "Software Onboard", "Servicios", "Automatización inteligente de procesos", "Business Process Outsourcing", "Auditoría Catastral", "Industrias", "Banca, Financieras y Seguros", "Real Estate y Servicing", "Gran Consumo", "Tecnología para gestión operativa"].map((item) => <a href="#" class={item === "Servicios" || item === "Industrias" ? "text-secondary" : "text-white"}>{item} <span class="float-right">→</span></a>)}</div>
        <div><a class="btn-primary" href={`mailto:${home.footer.email}`}>Contacto</a><p class="mt-6 text-sm leading-[18px]">{home.footer.email}</p><p class="mt-4 text-sm leading-[18px]">{home.footer.phone}</p><div class="mt-6 flex gap-2"><img src="/assets/figma/cert-bde.png" alt="" class="h-12 rounded bg-white p-2" /><img src="/assets/figma/cert-27001.png" alt="" class="h-12 rounded bg-white p-2" /><img src="/assets/figma/cert-9001.png" alt="" class="h-12 rounded bg-white p-2" /></div></div>
      </div>
    </footer>

    <script>
      const els = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("is-visible");
        });
      }, { threshold: 0.12 });
      els.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
