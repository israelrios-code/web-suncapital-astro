---
import "../styles/global.css";
import GoogleTagManagerHead from "../components/GoogleTagManagerHead.astro";
import GoogleTagManagerBody from "../components/GoogleTagManagerBody.astro";
import Nav from "../components/Nav.astro";
import home from "../content/home.json";

const serviceHrefs = [
  "/automatizacion-inteligente-de-procesos",
  "/business-process-outsourcing",
  "/auditoria-catastral",
];

const arrow = "→";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Suncapital</title>
    <meta name="description" content={home.hero.body} />
      <GoogleTagManagerHead />
  </head>
  <body>
    <GoogleTagManagerBody />
    <Nav />

    <main>
      <section class="relative min-h-[868px] overflow-hidden bg-ink pt-[252px] pb-[160px]">
        <img src={home.hero.image} alt="" class="absolute inset-y-0 right-0 h-full w-[78%] object-cover" />
        <div class="absolute inset-0 bg-[linear-gradient(82deg,#1d1d1b_27%,rgba(29,29,27,0)_87%),linear-gradient(0deg,#1d1d1b_5%,rgba(29,29,27,0)_45%),linear-gradient(90deg,rgba(29,29,27,.4),rgba(29,29,27,.4))]"></div>
        <div class="container-figma relative">
          <div class="max-w-[760px] reveal">
            <h1 class="text-white text-[64px] leading-[68px] font-bold tracking-normal max-lg:text-[44px] max-lg:leading-[48px]">
              {home.hero.title} <span class="text-secondary">{home.hero.highlight}</span>
            </h1>
            <p class="mt-10 max-w-[760px] text-white text-[18px] leading-[22px] font-medium">{home.hero.body}</p>
            <a href="#servicios" class="btn-primary mt-10">{home.hero.button}</a>
          </div>
        </div>
      </section>

      <section id="servicios" class="relative overflow-hidden bg-ink py-[120px] dark-orb">
        <div class="container-figma relative">
          <header class="text-center text-white reveal">
            <h2 class="section-title">{home.services.title}</h2>
            <p class="section-copy mt-[18px]">{home.services.body}</p>
          </header>
          <div class="mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1">
            {home.services.items.map((item, index) => (
              <article class="group reveal relative min-h-[582px] overflow-hidden rounded-[28px] border border-border p-10 flex flex-col justify-end">
                <img src={item.image} alt={item.title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-b from-[#dff1f900] to-[#dff1f9eb]"></div>
                <div class="relative">
                  <span class="inline-flex rounded-full bg-accent px-3 py-1 text-white text-sm leading-[18px]">{item.tag}</span>
                  <h3 class="card-title mt-4 text-primary">{item.title}</h3>
                  <p class="section-copy mt-4">{item.body}</p>
                  <a class="btn-primary mt-[18px]" href={serviceHrefs[index]}>{item.button}</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-surface py-[120px]">
        <div class="container-figma text-center reveal">
          <h2 class="section-title text-primary">{home.logos.title} <span class="text-accent">{home.logos.highlight}</span></h2>
          <p class="section-copy mt-4">{home.logos.body}</p>
          <div class="mt-20 grid grid-cols-9 gap-4 max-lg:grid-cols-3">
            {home.logos.items.map((logo) => <div class="h-[62px] rounded-lg bg-white flex items-center justify-center px-4"><img src={logo} alt="" class="max-h-[50px] object-contain" /></div>)}
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma">
          <div class="grid grid-cols-2 gap-20 items-center max-lg:grid-cols-1">
            <img src={home.audience.image} alt="" class="h-[368px] w-full rounded-3xl object-cover reveal" />
            <div class="reveal">
              <h2 class="section-title text-primary">{home.audience.title}</h2>
              <p class="section-copy mt-5">{home.audience.body}</p>
            </div>
          </div>
          <div class="mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1">
            {home.audience.items.map(([title, body]) => (
              <article class="reveal relative overflow-hidden rounded-3xl bg-ink p-8 min-h-[270px]">
                <div class="mb-[18px] flex size-12 items-center justify-center rounded-2xl bg-surface text-primary font-bold">□</div>
                <h3 class="card-title text-secondary">{title}</h3>
                <p class="section-copy mt-4 text-white">{body}</p>
              </article>
            ))}
          </div>
          <div class="mt-10 text-center"><a href="#contacto" class="btn-primary">{home.audience.button}</a></div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma reveal relative overflow-hidden rounded-3xl bg-ink p-10 dark-orb">
          <div class="relative grid grid-cols-[1fr_1.1fr] gap-20 items-center max-lg:grid-cols-1">
            <div>
              <h2 class="section-title text-white">{home.onboard.title} <span class="text-secondary">{home.onboard.highlight}</span></h2>
              <p class="section-copy mt-4 text-white">{home.onboard.body}</p>
              <div class="mt-6 grid gap-2">
                {home.onboard.items.map((item) => <div class="rounded bg-primary p-3 text-white section-copy">{item}</div>)}
              </div>
            </div>
            <div class="relative">
              <img src={home.onboard.image} alt="" class="w-full" />
              <img src={home.onboard.badge} alt="" class="absolute left-[45%] top-[-24px] w-[270px] rounded-lg shadow-2xl" />
            </div>
          </div>
        </div>
      </section>

      <section class="bg-surface py-20">
        <div class="container-figma">
          <header class="reveal">
            <h2 class="section-title text-primary">{home.benefits.title} <span class="text-accent">{home.benefits.highlight}</span></h2>
            <p class="section-copy mt-5 max-w-[683px]">{home.benefits.body}</p>
          </header>
          <div class="mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1">
            {home.benefits.items.map(([title, body]) => (
              <article class="reveal rounded-3xl border border-border bg-white p-8 min-h-[292px]">
                <div class="mb-[18px] flex size-12 items-center justify-center rounded-2xl bg-surface text-primary font-bold">⌁</div>
                <h3 class="card-title text-primary">{title}</h3>
                <p class="section-copy mt-4">{body}</p>
              </article>
            ))}
          </div>
          <div class="mt-10 text-center"><a class="btn-primary" href="#contacto">{home.benefits.button}</a></div>
        </div>
      </section>

      <section class="relative overflow-hidden bg-ink py-20 dark-orb">
        <div class="container-figma relative text-center text-white reveal">
          <h2 class="section-title">{home.stats.title} <span class="text-secondary">{home.stats.highlight}</span></h2>
          <p class="section-copy mt-[18px]">{home.stats.body}</p>
          <div class="mt-10 grid grid-cols-5 gap-6 text-left max-lg:grid-cols-1">
            {home.stats.items.map(([value, label]) => <div class="border-l border-white/25 pl-6 first:border-l-0 first:pl-0"><strong class="block text-secondary section-title">{value}</strong><span class="section-copy text-white">{label}</span></div>)}
          </div>
        </div>
      </section>

      <section id="industrias" class="rounded-3xl bg-surface py-20">
        <div class="container-figma text-center">
          <h2 class="section-title text-primary reveal">{home.industries.title} <span class="text-accent">{home.industries.highlight}</span> {home.industries.suffix}</h2>
          <p class="section-copy mt-[18px] text-slate-600 reveal">{home.industries.body}</p>
          <div class="mt-10 grid grid-cols-4 gap-5 text-left max-lg:grid-cols-1">
            {home.industries.items.map(([title, body, image]) => (
              <article class="reveal overflow-hidden rounded-3xl border border-border bg-white">
                <img src={image} alt={title} class="h-[268px] w-full object-cover" />
                <div class="p-8">
                  <h3 class="card-title text-primary">{title}</h3>
                  <p class="mt-3 text-sm leading-[18px]">{body}</p>
                </div>
              </article>
            ))}
          </div>
          <a href="#contacto" class="btn-primary mt-10">{home.industries.button}</a>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma grid grid-cols-[327px_1fr] gap-20 items-center max-lg:grid-cols-1">
          <header class="reveal">
            <span class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-primary section-copy"><i class="size-2 rounded-full bg-secondary"></i>{home.caseStudy.kicker}</span>
            <h2 class="section-title mt-[18px] text-primary">{home.caseStudy.title}</h2>
            <p class="section-copy mt-[18px]">{home.caseStudy.body}</p>
          </header>
          <article class="reveal rounded-3xl bg-primary p-10 text-white">
            <span class="mx-auto flex w-max rounded-full bg-secondary/20 px-3 py-1 text-secondary">{home.caseStudy.tag}</span>
            <div class="mt-8 grid grid-cols-3 gap-10 max-lg:grid-cols-1">
              {home.caseStudy.steps.map(([title, body], index) => <div><h3 class="text-surface font-semibold text-xl leading-8"><span class="mr-2 inline-grid size-6 place-items-center rounded-full bg-secondary text-primary text-base">{index + 1}</span>{title}</h3><p class="section-copy mt-3">{body}</p></div>)}
            </div>
            <div class="mt-8 grid grid-cols-3 gap-20 border-t border-white/60 pt-6 text-center max-lg:grid-cols-1">
              {home.caseStudy.metrics.map(([value, label]) => <div><strong class="section-title text-secondary">{value}</strong><p class="section-copy">{label}</p></div>)}
            </div>
          </article>
        </div>
      </section>

      <section class="bg-white py-20 text-center">
        <div class="container-figma reveal">
          <h2 class="section-title text-primary">{home.certifications.title}</h2>
          <p class="section-copy mx-auto mt-[18px] max-w-[1250px]">{home.certifications.body}</p>
          <div class="mt-10 grid grid-cols-4 gap-4 text-left max-lg:grid-cols-1">
            {home.certifications.items.map(([status, title, image]) => <article class="rounded-3xl bg-border p-8">{image && <img src={image} alt="" class="mb-4 h-[54px] w-[146px] object-contain rounded-lg bg-white p-2" />}<p class="text-accent text-[18px] leading-[22px] font-medium">{status}</p><h3 class="card-title mt-3 text-primary">{title}</h3></article>)}
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma grid grid-cols-[412px_1fr] gap-20 items-center max-lg:grid-cols-1">
          <div class="reveal"><h2 class="section-title text-primary">{home.awards.title}</h2><p class="section-copy mt-[18px]">{home.awards.body}</p></div>
          <div class="reveal flex items-center gap-10 max-lg:flex-wrap">{home.awards.images.map((image) => <img src={image} alt="" class="max-h-[100px] object-contain" />)}</div>
        </div>
      </section>

      <section id="sobre-nosotros" class="relative overflow-hidden bg-ink py-20 dark-orb">
        <div class="container-figma relative text-center text-white">
          <h2 class="section-title reveal">{home.team.title} <span class="text-secondary">{home.team.highlight}</span> {home.team.suffix}</h2>
          <p class="section-copy mt-[18px] reveal">{home.team.body}</p>
          <div class="mt-10 grid grid-cols-4 gap-6 text-left max-lg:grid-cols-1">
            {home.team.items.map(([name, role, image]) => <article class="reveal overflow-hidden rounded-3xl border border-border bg-white"><div class="relative"><img src={image} alt={name} class="h-[276px] w-full object-cover" /><span class="absolute left-5 top-5 rounded-2xl bg-surface px-3 py-2 text-primary font-bold">in</span></div><div class="p-8"><h3 class="card-title text-accent">{name}</h3><p class="mt-3 text-[18px] leading-[22px] font-medium text-ink">{role}</p></div></article>)}
          </div>
        </div>
      </section>

      <section id="contacto" class="bg-white py-20">
        <div class="container-figma reveal relative min-h-[526px] overflow-hidden rounded-3xl p-20 flex items-center">
          <img src={home.cta.image} alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-[linear-gradient(81deg,#1d1d1b_27%,rgba(29,29,27,0)_87%),linear-gradient(0deg,#1d1d1b_5%,rgba(29,29,27,0)_45%)]"></div>
          <div class="relative max-w-[640px] text-white">
            <h2 class="section-title">{home.cta.title}</h2>
            <p class="section-copy mt-5">{home.cta.body}</p>
            <a class="btn-primary mt-5" href={`mailto:${home.footer.email}`}>{home.cta.button}</a>
          </div>
        </div>
      </section>

      <section id="noticias" class="bg-white py-20">
        <div class="container-figma grid grid-cols-[338px_1fr] gap-20 items-start max-lg:grid-cols-1">
          <h2 class="section-title text-primary reveal">{home.faq.title}</h2>
          <div class="grid gap-5">
            {home.faq.items.map((item) => <details class="reveal group rounded-xl border-2 border-border px-[26px] py-[18px]"><summary class="flex cursor-pointer list-none items-center justify-between gap-8 card-title text-primary">{item}<span class="grid size-8 place-items-center rounded-full bg-surface text-primary text-base">+</span></summary><p class="section-copy mt-4 text-ink">Nuestro equipo revisa tu caso y te propone un camino de mejora medible, seguro y adaptado a tus sistemas actuales.</p></details>)}
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma text-center">
          <h2 class="section-title text-primary reveal">{home.news.title}</h2>
          <p class="section-copy mt-6 reveal">{home.news.body}</p>
          <div class="mt-12 grid grid-cols-3 gap-6 text-left max-lg:grid-cols-1">
            {home.news.items.map(([date, title, body, image]) => <article class="reveal overflow-hidden rounded-3xl border border-border bg-white"><img src={image} alt={title} class="h-[200px] w-full object-cover" /><div class="p-6"><p class="text-sm leading-[18px] text-ink/50">{date}</p><h3 class="mt-4 text-[18px] leading-[22px] font-medium text-primary">{title}</h3><p class="mt-4 text-sm leading-[18px]">{body}</p><a class="btn-text mt-4" href="#">Leer artículo {arrow}</a></div></article>)}
          </div>
        </div>
      </section>

      <section class="bg-surface py-20">
        <div class="container-figma text-center">
          <h2 class="section-title text-primary reveal">{home.cities.title}</h2>
          <p class="section-copy mt-6 reveal">{home.cities.body}</p>
          <div class="mt-12 grid grid-cols-3 gap-6 text-left max-lg:grid-cols-1">
            {home.cities.items.map(([title, body, button, image]) => <article class="reveal overflow-hidden rounded-3xl border border-border bg-white"><img src={image} alt={title} class="h-[286px] w-full object-cover" /><div class="p-6"><h3 class="text-[18px] leading-[22px] font-medium text-primary">{title}</h3><p class="mt-4 text-sm leading-[18px]">{body}</p><a class="btn-text mt-4 w-full justify-between" href="#contacto">{button} {arrow}</a></div></article>)}
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-ink py-20 text-white">
      <div class="container-figma grid grid-cols-4 gap-10 max-lg:grid-cols-1">
        <div>
          <strong class="block text-[30px] leading-none">SC <span class="text-white/60">|</span> <span class="text-[24px]">suncapital</span></strong>
          <p class="mt-6 font-manrope section-copy">{home.footer.body}</p>
          <p class="mt-6 font-manrope section-copy">© 2025 Suncapital. Todos los derechos reservados.</p>
          <div class="mt-6 grid gap-3 underline font-manrope section-copy"><a href="#">Política de Calidad y Seguridad</a><a href="#">Política de Privacidad</a><a href="#">Aviso Legal</a><a href="#">Canal Ético</a></div>
        </div>
        <div>
          <h3 class="font-manrope text-secondary text-[28px] leading-8 font-bold">Oficinas</h3>
          <p class="mt-6 font-manrope text-xl leading-6 font-bold">{home.footer.office}</p>
          <p class="mt-1 font-manrope section-copy">{home.footer.address}</p>
          <p class="mt-6 font-manrope section-copy">{home.footer.coverage}</p>
        </div>
        <div class="grid gap-4 text-[18px] leading-[22px] font-bold">
          {["Sobre nosotros", "Noticias", "Software Onboard", "Servicios", "Automatización inteligente de procesos", "Business Process Outsourcing", "Auditoría Catastral", "Industrias", "Banca, Financieras y Seguros", "Real Estate y Servicing", "Gran Consumo", "Tecnología para gestión operativa"].map((item) => <a href="#" class={item === "Servicios" || item === "Industrias" ? "text-secondary" : "text-white"}>{item} <span class="float-right">{arrow}</span></a>)}
        </div>
        <div>
          <a class="btn-primary" href={`mailto:${home.footer.email}`}>Contacto</a>
          <p class="mt-6 text-sm leading-[18px]">{home.footer.email}</p>
          <p class="mt-4 text-sm leading-[18px]">{home.footer.phone}</p>
          <div class="mt-6 flex gap-2"><img src="/assets/figma/cert-bde.png" alt="" class="h-12 rounded bg-white p-2" /><img src="/assets/figma/cert-27001.png" alt="" class="h-12 rounded bg-white p-2" /><img src="/assets/figma/cert-9001.png" alt="" class="h-12 rounded bg-white p-2" /></div>
        </div>
      </div>
    </footer>

    <script>
      const els = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("is-visible");
        });
      }, { threshold: 0.12 });
      els.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
