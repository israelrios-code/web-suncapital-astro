---
import "../styles/global.css";
import GoogleTagManagerHead from "../components/GoogleTagManagerHead.astro";
import GoogleTagManagerBody from "../components/GoogleTagManagerBody.astro";
import Nav from "../components/Nav.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import data from "../content/onboard.json";
import home from "../content/home.json";

const capabilityIcons = [
  "/assets/icons/icon-ob-face-id.svg",
  "/assets/icons/icon-ob-file-shield.svg",
  "/assets/icons/icon-ob-check-verified.svg",
  "/assets/icons/icon-ob-code-snippet.svg",
  "/assets/icons/icon-ob-dataflow-04.svg",
  "/assets/icons/icon-ob-clock.svg",
];
const processIcons = [
  "/assets/icons/icon-ob-step1.svg",
  "/assets/icons/icon-ob-step2.svg",
  "/assets/icons/icon-ob-step3.svg",
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Software Onboard | Suncapital</title>
    <meta name="description" content={data.hero.body} />
      <GoogleTagManagerHead />
  </head>
  <body>
    <GoogleTagManagerBody />
    <Nav />

    <main class="pt-[102px] bg-white">
      <Breadcrumb current="Software Onboard" />
      <section class="relative overflow-hidden bg-ink py-[120px] max-lg:py-[60px] dark-orb">
        <img src="/assets/deco/lineas-hero-todas-las-secciones.svg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none z-[1] opacity-20" />
        <div class="container-figma relative grid grid-cols-[760px_1fr] gap-20 items-center max-lg:grid-cols-1">
          <div class="reveal">
            <h1 class="text-white text-[64px] leading-[68px] font-bold max-lg:text-[44px] max-lg:leading-[48px]">
              <span class="text-accent">{data.hero.titleStart}</span> {data.hero.title}
            </h1>
            <p class="mt-10 text-white text-[18px] leading-[22px] font-medium">{data.hero.body}</p>
            <a href="#demo" class="btn-primary mt-10">{data.hero.button}</a>
          </div>
          <div class="relative reveal">
            <img src={data.hero.image} alt="" class="w-full drop-shadow-2xl" />
            <img src={data.hero.badge} alt="Onboard by Suncapital" class="absolute left-[23%] top-[-58px] w-[270px] rounded-lg shadow-2xl max-lg:top-[-30px] max-lg:w-[200px]" />
          </div>
        </div>
      </section>

      <section id="demo" class="bg-surface py-20 max-lg:py-[60px]">
        <div class="container-figma grid grid-cols-[634px_1fr] gap-20 items-center max-lg:grid-cols-1">
          <div class="relative h-[487px] max-lg:h-[300px] reveal">
            <img src={data.problem.image} alt="" class="absolute left-[25px] top-[32px] h-[420px] w-[560px] rounded-3xl object-cover max-lg:left-0 max-lg:top-0 max-lg:w-full max-lg:h-full" />
            <div class="absolute right-0 top-0 rounded-xl bg-secondary p-3 text-center text-primary shadow-xl">
              <p class="section-copy">MiFID II</p>
              <p class="text-xs leading-4">Compliant</p>
            </div>
            <div class="absolute left-0 bottom-0 w-[223px] rounded-xl bg-white p-5 shadow-2xl">
              <div class="flex gap-3 items-center">
                <div class="flex size-11 shrink-0 items-center justify-center rounded-full bg-surface">
                  <img src="/assets/icons/icon-ob-shield-tick.svg" alt="" class="size-5 object-contain" />
                </div>
                <div><p class="text-xs leading-4">Estado del proceso</p><p class="text-primary section-copy">Onboarding KYC</p></div>
              </div>
              <ul class="mt-3 grid gap-1.5 text-xs leading-4">
                <li><span class="mr-2 inline-block size-2 rounded-full bg-secondary"></span>Verificación documental</li>
                <li><span class="mr-2 inline-block size-2 rounded-full bg-secondary"></span>Validación identidad</li>
                <li><span class="mr-2 inline-block size-2 rounded-full bg-surface"></span>Firma electrónica</li>
              </ul>
            </div>
          </div>
          <div class="reveal">
            <span class="inline-flex items-center gap-2 rounded-full bg-accent px-4 py-2.5 text-white section-copy"><i class="size-2 rounded-full bg-secondary"></i>{data.problem.chip}</span>
            <h2 class="section-title mt-4 text-primary">{data.problem.title} <span class="text-accent">{data.problem.highlight}</span></h2>
            <p class="section-copy mt-4">{data.problem.body}</p>
            <div class="mt-8 grid grid-cols-2 gap-4 max-lg:grid-cols-1">
              <div class="rounded-xl border border-border bg-white p-5 text-sm leading-[18px]">{data.problem.insights[0]}</div>
              <div class="rounded-xl border border-border bg-white p-5"><h3 class="text-primary text-[18px] leading-[22px] font-medium">El Resultado:</h3><p class="mt-3 text-sm leading-[18px]">{data.problem.insights[1]}</p></div>
            </div>
            <a href="#contacto" class="btn-primary mt-8">{data.problem.button} <span class="ml-3">→</span></a>
          </div>
        </div>
      </section>

      <section class="bg-white py-20 max-lg:py-[60px]">
        <div class="container-figma">
          <h2 class="section-title text-center text-primary reveal">{data.capabilities.title}</h2>
          <div class="mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1">
            {data.capabilities.items.map(([title, body, link], index) => (
              <article class="reveal relative min-h-[330px] overflow-hidden rounded-3xl bg-ink p-8 text-white dark-card">
                <div class="relative">
                  <div class="mb-[18px] flex size-12 items-center justify-center rounded-2xl bg-surface">
                    <img src={capabilityIcons[index]} alt="" class="size-6 object-contain" />
                  </div>
                  <h3 class="card-title text-secondary">{title}</h3>
                  <p class="section-copy mt-4">{body}</p>
                  <a href="#contacto" class="btn-text btn-text-white mt-8">{link} →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="relative overflow-hidden bg-ink py-[120px] max-lg:py-[60px] dark-orb">
        <div class="container-figma relative text-center text-white">
          <h2 class="section-title reveal">{data.industries.title}</h2>
          <p class="section-copy mt-[18px] reveal">{data.industries.body}</p>
          <div class="mt-10 grid grid-cols-2 gap-6 text-left max-lg:grid-cols-1">
            {data.industries.items.map(([title, body, button, image]) => (
              <article class="group reveal relative min-h-[468px] overflow-hidden rounded-[28px] p-10 flex flex-col justify-end">
                <img src={image} alt={title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-[#0F172A]/70"></div>
                <div class="relative">
                  <h3 class="card-title text-white">{title}</h3>
                  <p class="section-copy mt-4 text-white/80">{body}</p>
                  <a class="btn-primary mt-[18px]" href="#contacto">{button}</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-surface py-[120px] max-lg:py-[60px]">
        <div class="container-figma text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-border bg-white px-4 py-2.5 text-primary text-sm leading-[18px] reveal"><i class="size-2 rounded-full bg-secondary"></i>{data.process.chip}</span>
          <h2 class="section-title mt-4 text-primary reveal">{data.process.title}</h2>
          <div class="mt-10 grid grid-cols-3 gap-6 text-left max-lg:grid-cols-1">
            {data.process.items.map(([num, title, body], index) => (
              <article class="reveal rounded-3xl border border-border bg-primary p-10 text-white min-h-[416px]">
                <div class="flex items-center justify-between">
                  <span class="text-[64px] leading-[68px] font-bold text-white/20">{num}</span>
                  <div class="flex size-12 items-center justify-center rounded-2xl bg-accent">
                    <img src={processIcons[index]} alt="" class="size-6 object-contain" />
                  </div>
                </div>
                <h3 class="card-title mt-8">{title}</h3>
                <p class="mt-8 text-[16px] leading-5 font-medium">{body}</p>
              </article>
            ))}
          </div>
          <a href="#contacto" class="btn-primary mt-10">{data.process.button}</a>
        </div>
      </section>

      <section id="contacto" class="bg-white py-20 max-lg:py-[60px]">
        <div class="container-figma reveal relative min-h-[510px] overflow-hidden rounded-3xl p-20 flex items-end max-lg:p-5">
          <img src={data.cta.image} alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-[linear-gradient(80deg,#1d1d1b_27%,rgba(29,29,27,0)_87%),linear-gradient(0deg,#1d1d1b_5%,rgba(29,29,27,0)_45%)]"></div>
          <img src="/assets/deco/lineas-hero-banner.svg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none z-[1] opacity-20" />
          <div class="relative z-[2] max-w-[640px] text-white">
            <h2 class="section-title">{data.cta.title}</h2>
            <p class="section-copy mt-5">{data.cta.body}</p>
            <a class="btn-primary mt-5" href={`mailto:${home.footer.email}`}>{data.cta.button}</a>
          </div>
        </div>
      </section>

      <section class="bg-white py-20 max-lg:py-[60px]">
        <div class="container-figma grid grid-cols-[338px_1fr] gap-20 max-lg:gap-8 items-start max-lg:grid-cols-1">
          <h2 class="section-title text-primary reveal">{data.faq.title}</h2>
          <div class="grid gap-5">
            {data.faq.items.map(([question, answer]) => (
              <details class="reveal group rounded-xl border-2 border-border px-[26px] py-[18px]">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-6 card-title max-lg:text-[18px] max-lg:leading-[22px] text-primary group-open:text-accent">
                  {question}
                  <span class="grid size-8 shrink-0 place-items-center rounded-full bg-surface text-primary text-base group-open:bg-accent group-open:text-white">
                    <span class="group-open:hidden">+</span>
                    <span class="hidden group-open:inline leading-none">−</span>
                  </span>
                </summary>
                <p class="section-copy mt-4 text-ink">{answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-ink py-20 text-white">
      <div class="container-figma grid grid-cols-4 gap-10 max-lg:grid-cols-1">
        <div>
          <a href="/"><img src="/assets/logo-footer.svg" alt="Suncapital" width="270" height="40" class="h-9 w-auto" /></a>
          <p class="mt-6 font-manrope section-copy">{home.footer.body}</p>
          <a href="https://www.linkedin.com/company/suncapital" target="_blank" rel="noopener noreferrer" class="mt-6 block w-max"><img src="/assets/icons/icon-linkedin-social.svg" alt="LinkedIn Suncapital" width="30" height="30" class="w-10 h-10" /></a><p class="mt-6 font-manrope section-copy">© 2025 Suncapital. Todos los derechos reservados.</p>
          <div class="mt-6 grid gap-3 underline font-manrope section-copy"><a href="#">Política de Calidad y Seguridad</a><a href="#">Política de Privacidad</a><a href="#">Aviso Legal</a><a href="#">Canal Ético</a></div>
        </div>
        <div><h3 class="font-manrope text-secondary text-[28px] leading-8 font-bold">Oficinas</h3><p class="mt-6 font-manrope text-xl leading-6 font-bold">{home.footer.office}</p><p class="mt-1 font-manrope section-copy">{home.footer.address}</p><p class="mt-6 font-manrope section-copy">{home.footer.coverage}</p></div>
        <div class="grid gap-4 text-[18px] leading-[22px] font-bold">{[["Sobre nosotros","/sobre-nosotros"],["Noticias","/noticias"],["Software Onboard","/onboard"],["Servicios","/#servicios"],["Automatización inteligente de procesos","/automatizacion-inteligente-de-procesos"],["Business Process Outsourcing","/business-process-outsourcing"],["Auditoría Catastral","/auditoria-catastral"],["Industrias","/#industrias"],["Banca, Financieras y Seguros","/banca-financieras-seguros"],["Real Estate y Servicing","/real-estate-servicing"],["Gran Consumo","/gran-consumo"],["Tecnología para gestión operativa","/tecnologia-gestion-operativa"]].map(([label, href]) => <a href={href} class={`${label === "Servicios" || label === "Industrias" ? "text-secondary" : "text-white"} hover:text-secondary transition-colors`}>{label}{label !== "Servicios" && label !== "Industrias" && <span class="float-right">→</span>}</a>)}</div>
        <div><a class="btn-primary" href={`mailto:${home.footer.email}`}>Contacto</a><p class="mt-6 text-sm leading-[18px]">{home.footer.email}</p><p class="mt-4 text-sm leading-[18px]">{home.footer.phone}</p><div class="mt-6 flex flex-col gap-2"><div class="flex gap-2"><img src="/assets/figma/cert-27001.svg" alt="ISO 27001" class="h-16 rounded bg-white p-2 object-contain" /><img src="/assets/figma/cert-9001.svg" alt="ISO 9001" class="h-16 rounded bg-white p-2 object-contain" /></div><img src="/assets/figma/cert-bde.svg" alt="Banco de España" class="h-20 w-full rounded bg-white p-1 object-contain" /></div></div>
      </div>
    </footer>

    <script>
      const els = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("is-visible");
        });
      }, { threshold: 0.12 });
      els.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
