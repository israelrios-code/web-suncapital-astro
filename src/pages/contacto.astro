---
import "../styles/global.css";
import GoogleTagManagerHead from "../components/GoogleTagManagerHead.astro";
import GoogleTagManagerBody from "../components/GoogleTagManagerBody.astro";
import Nav from "../components/Nav.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import data from "../content/contact.json";
import home from "../content/home.json";

---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Contacto | Suncapital</title>
    <meta name="description" content={data.hero.body} />
      <GoogleTagManagerHead />
  </head>
  <body>
    <GoogleTagManagerBody />
    <Nav />

    <main class="pt-[102px] bg-white">
      <Breadcrumb current="Contacto" />
      <section class="relative overflow-hidden bg-ink py-20">
        <div class="absolute right-[-180px] top-[-328px] h-[1097px] w-[878px] rotate-[-6deg] rounded-[50%] border border-white/25"></div>
        <div class="absolute left-1/2 top-[317px] size-[1161px] rounded-full bg-primary/40 blur-[150px]"></div>
        <div class="absolute left-[63%] top-10 size-[1015px] rounded-full bg-secondary/20 blur-[150px]"></div>
        <div class="container-figma relative grid grid-cols-[760px_1fr] gap-20 items-center max-lg:grid-cols-1">
          <div class="reveal text-white">
            <h1 class="text-[68px] leading-[72px] font-bold max-lg:text-[44px] max-lg:leading-[48px]">
              {data.hero.title.split(data.hero.highlight)[0]}<span class="text-accent">{data.hero.highlight}</span>
            </h1>
            <p class="mt-10 text-[18px] leading-[22px] font-medium">{data.hero.body}</p>
          </div>

          <form class="reveal rounded-3xl border border-white/10 bg-accent p-[29px] text-white shadow-2xl">
            <div class="grid gap-4">
              {data.form.fields.map((field) => (
                <label class="grid gap-3 text-[16px] leading-5">
                  <span>{field.label}</span>
                  {field.type === "select" ? (
                    <select class="h-[46px] w-full rounded-2xl border border-surface bg-transparent px-4 py-3 text-[14px] leading-[18px] text-surface/70 outline-none">
                      <option>{field.placeholder}</option>
                      <option>Automatización de procesos</option>
                      <option>BPO operativo</option>
                      <option>Auditoría catastral</option>
                    </select>
                  ) : (
                    <input type={field.type} placeholder={field.placeholder} class="h-[46px] w-full rounded-2xl border border-surface bg-transparent px-4 py-3 text-[14px] leading-[18px] text-white outline-none placeholder:text-surface/40" />
                  )}
                </label>
              ))}
            </div>
            <button class="mt-8 flex h-14 w-full items-center justify-center gap-3 rounded-full bg-secondary px-7 py-4 text-primary text-[20px] leading-6 font-bold shadow-lg transition hover:-translate-y-0.5 hover:shadow-xl" type="button">
              {data.form.button}<span aria-hidden="true">→</span>
            </button>
            <p class="mx-auto mt-8 max-w-[440px] text-center text-[14px] leading-[18px] text-surface">{data.form.note}</p>
          </form>
        </div>
      </section>

      <section class="bg-surface py-[120px]">
        <div class="container-figma text-center">
          <h2 class="reveal text-primary text-[48px] leading-[52px] font-bold">{data.process.title}</h2>
          <div class="mt-10 grid grid-cols-3 gap-6 text-left max-lg:grid-cols-1">
            {data.process.items.map((item) => (
              <article class="reveal min-h-[360px] rounded-3xl border border-border bg-primary p-10 text-white">
                <div class="flex items-center justify-between">
                  <p class="text-[68px] leading-[72px] font-bold text-white/20">{item.number}</p>
                  <span class="grid size-12 place-items-center rounded-2xl bg-accent text-xl">{item.icon}</span>
                </div>
                <h3 class="mt-8 text-[28px] leading-8 font-semibold">{item.title}</h3>
                <p class="mt-8 text-[16px] leading-5 font-medium">{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-white py-20">
        <div class="container-figma grid grid-cols-[338px_1fr] gap-20 items-start max-lg:grid-cols-1">
          <h2 class="reveal text-primary text-[48px] leading-[52px] font-bold">{data.faq.title}</h2>
          <div class="grid gap-5">
            {data.faq.items.map((item) => (
              <details open class="reveal rounded-xl border-2 border-border px-[26px] py-[18px]">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-8 text-accent text-[28px] leading-8 font-semibold">
                  {item.question}<span class="grid size-8 shrink-0 place-items-center rounded-full bg-accent text-white text-base">−</span>
                </summary>
                <p class="mt-6 text-[16px] leading-5 text-ink">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-border py-20">
        <div class="container-figma">
          <h2 class="reveal text-primary text-[48px] leading-[52px] font-bold">{data.locations.title}</h2>
          <a class="reveal mt-[18px] inline-flex items-center gap-3 text-accent text-[20px] leading-6 font-semibold" href={`tel:${data.locations.phone.replace(/[^+\d]/g, "")}`}>
            <span aria-hidden="true">⌕</span>{data.locations.phone}
          </a>
          <div class="mt-10 grid grid-cols-5 gap-3 max-xl:grid-cols-3 max-lg:grid-cols-2 max-sm:grid-cols-1">
            {data.locations.items.map((office) => (
              <article class="reveal rounded-lg border border-border bg-white p-[15px]">
                <span class="text-primary text-[28px] leading-none">⌖</span>
                <h3 class="mt-2 text-primary text-[20px] leading-6 font-semibold">{office.city}</h3>
                <p class="mt-2 text-[16px] leading-5 text-ink">{office.address}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-ink py-20 text-white">
      <div class="container-figma grid grid-cols-4 gap-10 max-lg:grid-cols-1">
        <div>
          <strong class="block text-[30px] leading-none">SC <span class="text-white/60">|</span> <span class="text-[24px]">suncapital</span></strong>
          <p class="mt-6 font-manrope section-copy">{home.footer.body}</p>
          <p class="mt-6 font-manrope section-copy">© 2025 Suncapital. Todos los derechos reservados.</p>
          <div class="mt-6 grid gap-3 underline font-manrope section-copy"><a href="#">Política de Calidad y Seguridad</a><a href="#">Política de Privacidad</a><a href="#">Aviso Legal</a><a href="#">Canal Ético</a></div>
        </div>
        <div><h3 class="font-manrope text-secondary text-[28px] leading-8 font-bold">Oficinas</h3><p class="mt-6 font-manrope text-xl leading-6 font-bold">{home.footer.office}</p><p class="mt-1 font-manrope section-copy">{home.footer.address}</p><p class="mt-6 font-manrope section-copy">{home.footer.coverage}</p></div>
        <div class="grid gap-4 text-[18px] leading-[22px] font-bold">{["Sobre nosotros", "Noticias", "Software Onboard", "Servicios", "Automatización inteligente de procesos", "Business Process Outsourcing", "Auditoría Catastral", "Industrias", "Banca, Financieras y Seguros", "Real Estate y Servicing", "Gran Consumo", "Tecnología para gestión operativa"].map((item) => <a href="#" class={item === "Servicios" || item === "Industrias" ? "text-secondary" : "text-white"}>{item} <span class="float-right">→</span></a>)}</div>
        <div><a class="btn-primary" href={`mailto:${home.footer.email}`}>Contacto</a><p class="mt-6 text-sm leading-[18px]">{home.footer.email}</p><p class="mt-4 text-sm leading-[18px]">{home.footer.phone}</p><div class="mt-6 flex gap-2"><img src="/assets/figma/cert-bde.png" alt="" class="h-12 rounded bg-white p-2" /><img src="/assets/figma/cert-27001.png" alt="" class="h-12 rounded bg-white p-2" /><img src="/assets/figma/cert-9001.png" alt="" class="h-12 rounded bg-white p-2" /></div></div>
      </div>
    </footer>

    <script>
      const els = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("is-visible");
        });
      }, { threshold: 0.12 });
      els.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
